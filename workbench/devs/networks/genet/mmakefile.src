
include $(SRCDIR)/config/aros.cfg

#MM- workbench-devs-networks-genet-aarch64 : workbench-devs-networks-genet

FILES := handler unit genet_hw genet_phy

CFLAGSNORMAL = $(CFLAGS) -DDEBUG=0
CFLAGSDEBUG = $(CFLAGS) -DDEBUG=1
USER_LDFLAGS := -static

#MM- workbench-devs-networks-genet : workbench-devs-networks-genet-normal

%build_module mmake=workbench-devs-networks-genet-normal \
    modname=genet modtype=device \
    files="genet_init $(FILES)" cflags=$(CFLAGSNORMAL) \
    objdir=$(OBJDIR)/normal moduledir=Devs/Networks

%common
