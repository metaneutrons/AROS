
include $(SRCDIR)/config/aros.cfg

#MM- workbench-devs-networks-dwmac-aarch64 : workbench-devs-networks-dwmac

FILES := handler dwmac_hw

USER_INCLUDES := -I$(SRCDIR)/arch/aarch64-native/kernel
USER_LDFLAGS := -static

%build_module mmake=workbench-devs-networks-dwmac \
    modname=dwmac modtype=device \
    files="dwmac_init $(FILES)" \
    moduledir=Devs/Networks

%common
