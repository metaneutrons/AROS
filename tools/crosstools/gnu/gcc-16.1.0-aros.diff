+
+do_fpus := vfp vfpv2 vfpv3 vfpv3-fp16 vfpv3-d16 vfpv3-d16-fp16 neon neon-vfpv3 \
+           neon-fp16 vfpv4 neon-vfpv4 vfpv4-d16 fpv5-d16 fp-armv8 neon-fp-armv8 \
