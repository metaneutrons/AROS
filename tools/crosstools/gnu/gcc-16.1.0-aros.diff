+
+#undef SIZE_TYPE
+#define SIZE_TYPE "long unsigned int"
+
+#undef	WCHAR_TYPE
+#define WCHAR_TYPE "unsigned int"
+
+#undef	WCHAR_TYPE_SIZE
+#define WCHAR_TYPE_SIZE 32
+
