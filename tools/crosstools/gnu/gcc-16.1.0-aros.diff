+MULTILIB_REUSE		+= marm/mlittle-endian/march.armv7-a+nofp/mfloat-abi.soft=mlittle-endian/march.armv7-a+fp/mfloat-abi.soft
+MULTILIB_REUSE		+= marm/mlittle-endian/march.armv7-a+nofp/mfloat-abi.soft=marm/mlittle-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.soft
+MULTILIB_REUSE		+= marm/mlittle-endian/march.armv7-a+nofp/mfloat-abi.soft=mlittle-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.soft
