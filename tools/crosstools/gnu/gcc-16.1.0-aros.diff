+MULTILIB_REQUIRED	+= marm/mlittle-endian/march=armv7-a+fp/mfpu=vfpv3-d16/mfloat-abi=hard
+MULTILIB_REQUIRED	+= marm/mlittle-endian/march=armv7-a+fp/mfpu=neon/mfloat-abi=softfp
+MULTILIB_REQUIRED	+= marm/mlittle-endian/march=armv7-a+fp/mfpu=neon/mfloat-abi=hard
+MULTILIB_REQUIRED	+= marm/mbig-endian/march=armv7-a+nofp/mfloat-abi=soft
