+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+nofp/mfloat-abi.soft=marm/mbig-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.soft
+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+nofp/mfloat-abi.soft=mbig-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.soft
+
+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+fp/mfpu.vfpv3-d16/mfloat-abi.hard=marm/mbig-endian/march.armv7-a+fp/mfloat-abi.hard
+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+fp/mfpu.vfpv3-d16/mfloat-abi.hard=mbig-endian/march.armv7-a+fp/mfloat-abi.hard
+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+fp/mfpu.vfpv3-d16/mfloat-abi.hard=mbig-endian/march.armv7-a+fp/mfpu.vfpv3-d16/mfloat-abi.hard
+MULTILIB_REUSE		+= marm/mbig-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.hard=mbig-endian/march.armv7-a+fp/mfpu.neon/mfloat-abi.hard
+
